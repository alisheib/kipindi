// StoreSnapshot dropped in Phase 0d — all entities now in dedicated tables.
// Migration 20260702150000 drops the table.

// ============================================================================
// IDENTITY & ACCESS
// ============================================================================

model User {
  id                   String     @id @default(cuid())
  phoneE164            String     @unique
  email                String?
  emailVerifiedAt      DateTime?
  passwordHash         String?
  passwordSalt         String?
  failedLoginCount     Int        @default(0)
  lockedUntil          DateTime?
  role                 UserRole   @default(PLAYER)
  status               UserStatus @default(PENDING_KYC)
  locale               Locale     @default(SW)
  displayName          String?
  dob                  DateTime?
  region               String?
  acceptedTermsVersion String?
  acceptedTermsAt      DateTime?
  marketingOptIn       Boolean    @default(false)
  twoFactorEnabled     Boolean    @default(false)
  avatarDataUrl        String?    @db.Text
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  lastLoginAt          DateTime?
  closedAt             DateTime?

  wallet                  Wallet?
  kycSubmissions          KycSubmission[]
  transactions            Transaction[]
  sessions                Session[]
  otps                    Otp[]
  devices                 Device[]
  flags                   AntiFraudFlag[]      @relation("FlaggedUser")
  reviewedFlags           AntiFraudFlag[]      @relation("FlagReviewer")
  responsibleGambling     ResponsibleGambling?
  notifications           Notification[]
  affiliateAgent          AffiliateAgent?
  recruitedBy             String?
  recruitedById           AffiliateAgent?      @relation("AgentRecruits", fields: [recruitedBy], references: [userId])
  sourceOfFunds           SourceOfFunds?
  referralRewardsGiven    ReferralReward[]     @relation("ReferralRewardsGiven")
  referralRewardsReceived ReferralReward[]     @relation("ReferralRewardsReceived")
  proposals               Proposal[]
  objections              Objection[]
  proposalVotes           ProposalVote[]
  positions               Position[]
  marketComments          Comment[]
  totpSecret              TotpSecret?
  totpBackupCodes         TotpBackupCode[]
  watchlist               Watchlist[]
  pushSubscriptions       PushSubscription[]
  bonusGrants             BonusGrant[]
  inviteCampaigns         InviteCampaign[]

  @@index([role, status])
  @@index([createdAt])
}

model Session {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash    String    @unique
  ip           String?
  userAgent    String?
  deviceId     String?
  device       Device?   @relation(fields: [deviceId], references: [id])
  createdAt    DateTime  @default(now())
  expiresAt    DateTime
  revokedAt    DateTime?
  lastActiveAt DateTime  @default(now())

  @@index([userId, revokedAt])
}

model Otp {
  id         String    @id @default(cuid())
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  phoneE164  String
  codeHash   String
  purpose    String // login, register, withdraw, reauth, password_reset
  attempts   Int       @default(0)
  consumedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  @@index([phoneE164, purpose])
  @@index([expiresAt])
}

model Device {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fingerprint String
  platform    String? // ios, android, web
  model       String?
  osVersion   String?
  appVersion  String?
  pushToken   String?
  firstSeenAt DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  trustedAt   DateTime?
  blockedAt   DateTime?

  sessions Session[]

  @@unique([userId, fingerprint])
  @@index([fingerprint])
}

// ============================================================================
// KYC / AML
// ============================================================================

model KycSubmission {
  id             String           @id @default(cuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  status         KycStatus        @default(IN_PROGRESS)
  rejectReason   KycRejectReason?
  rejectNote     String?
  nidaNumber     String?
  nidaVerifiedAt DateTime?
  fullName       String?
  dob            DateTime?
  gender         String?
  reviewerId     String?
  reviewedAt     DateTime?
  submittedAt    DateTime?
  /** Officer-requested extra documents (each with a description). JSON array of
   *  { id, description, requestedAt, storageKey, uploadedAt }. Empty normally. */
  extraRequests  Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  documents KycDocument[]

  @@index([userId, status])
  @@index([status, submittedAt])
  @@index([nidaNumber])
}

model KycDocument {
  id           String        @id @default(cuid())
  submissionId String
  submission   KycSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  docType      DocType
  // M8/H8: written + read through the storage seam (src/lib/server/storage.ts).
  // Default (INLINE) → an image data URL (`data:image/...;base64,...`) stored in
  // Postgres. With `KYC_STORAGE=r2` + R2 creds → an `r2:<key>` reference to a
  // Cloudflare R2 (S3-compatible) object; `readKycDocument` routes by key shape,
  // so old inline rows keep working after switching new uploads to R2.
  storageKey   String
  mimeType     String
  sizeBytes    Int
  uploadedAt   DateTime      @default(now())
  blurScore    Float?
  ocrText      String?
  rejected     Boolean       @default(false)
  rejectReason String?
}

// ============================================================================
// WALLET & TRANSACTIONS
// ============================================================================

// CHECK constraints applied via migration 20260702140000:
//   balance >= 0, hold >= 0, bonusBalance >= 0
model Wallet {
  id        String       @id @default(cuid())
  userId    String       @unique
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    WalletStatus @default(ACTIVE)
  balance   Decimal      @default(0) @db.Decimal(18, 2)
  pending   Decimal      @default(0) @db.Decimal(18, 2)
  hold      Decimal      @default(0) @db.Decimal(18, 2)
  // Non-withdrawable promotional funds. Held separately from `balance` so bonus
  // money can never be withdrawn until its wagering requirement is met (at which
  // point bonus-service moves the remainder into `balance`). Invariant:
  // bonusBalance == Σ remainingTzs over the wallet's ACTIVE BonusGrants.
  bonusBalance Decimal   @default(0) @db.Decimal(18, 2)
  currency  String       @default("TZS")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  transactions Transaction[]
  bonusGrants  BonusGrant[]

  @@index([status])
}

model Transaction {
  id              String           @id @default(cuid())
  walletId        String
  wallet          Wallet           @relation(fields: [walletId], references: [id], onDelete: Cascade)
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            TxnType
  status          TxnStatus        @default(PENDING)
  amount          Decimal          @db.Decimal(18, 2)
  fee             Decimal          @default(0) @db.Decimal(18, 2)
  taxWithheld     Decimal          @default(0) @db.Decimal(18, 2)
  balanceAfter    Decimal?         @db.Decimal(18, 2)
  currency        String           @default("TZS")
  provider        PaymentProvider?
  providerRef     String?
  providerStatus  String?
  msisdn          String? // recipient/sender phone for mobile money
  description     String?
  // Soft reference to the prediction-market Position this ledger entry belongs
  // to. Null for non-wager transactions (deposits, withdrawals, bonuses).
  // Kept as a plain string (no DB-level FK) so the append-only ledger is never
  // blocked by cascade or missing-row errors.
  positionId      String?
  amlReviewedById String?
  amlReviewedAt   DateTime?
  amlReason       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  completedAt     DateTime?
  // Client-generated UUID — prevents double-submit on 2G (same key = same intent).
  // Nullable: internal txns (settlement, refund) don't carry one.
  idempotencyKey  String?          @unique
  // Stamped when we email the player that this deposit is TAKING A WHILE (the
  // reconcile sweep does it, not the initiate path — see notifyStillPendingDeposits).
  // Its only job is exactly-once: the sweep re-runs on a schedule and would
  // otherwise re-send the same "still waiting" mail every cycle. Same pattern as
  // Market.selectionClosedNotifiedAt. Null = not yet told / not applicable.
  pendingNotifiedAt DateTime?

  // Prevent duplicate deposits/withdrawals from the same payment provider
  // transaction. A retried webhook with the same providerRef must not
  // create a second ledger entry. Nulls are excluded (internal txns).
  @@unique([provider, providerRef])
  @@index([userId, createdAt])
  @@index([walletId, createdAt])
  @@index([type, status])
  @@index([providerRef])
}

// ============================================================================
// BONUS WALLET — non-withdrawable promotional grants with wagering requirements
// ============================================================================
//
// A BonusGrant is one promotional credit (admin gift, affiliate reward, proposal
// prize, invite-campaign bonus, future cashback). It lives in Wallet.bonusBalance
// and is NOT withdrawable until its wagering requirement (amount × multiplier of
// turnover) is met — at which point bonus-service moves `remainingTzs` into the
// real `balance` and marks the grant FULFILLED. Per Ali (2026-06-26): grants
// accumulate (FIFO wagering, no one-at-a-time restriction); withdrawing real
// balance leaves active bonuses untouched (coexist).

enum BonusSource {
  ADMIN       // manual operator grant
  REFERRAL    // affiliate reward routed to bonus
  PROPOSAL    // proposal prize routed to bonus
  INVITE      // bulk invite-campaign bonus
  PROMOTION   // generic marketing promotion
  CASHBACK    // deposit-loss cashback (deferred feature; enum reserved)
}

enum BonusGrantStatus {
  ACTIVE      // wagering in progress; remainingTzs sits in bonusBalance
  QUEUED      // sequential mode §6: waiting for the current bonus to finish before activating
  FULFILLED   // wagering met; remainingTzs converted to real balance
  EXPIRED     // expiresAt passed before fulfilment; remainder removed
  CANCELLED   // admin/player cancelled; remainder removed
  FORFEITED   // forfeited (reserved for policies that void on withdrawal)
}

model BonusGrant {
  id               String           @id // bg_{id}
  userId           String
  walletId         String
  amountTzs        Int                              // original grant amount
  remainingTzs     Int                              // unspent portion (in bonusBalance)
  wagerMultiplier  Decimal          @db.Decimal(4, 1) // e.g. 5.0
  wagerRequiredTzs Int                              // amountTzs × multiplier (precomputed turnover target)
  wageredTzs       Int              @default(0)     // turnover accrued toward the requirement
  source           BonusSource
  sourceRef        String?          @unique          // idempotency key (NULLs allowed/non-conflicting in Postgres)
  status           BonusGrantStatus @default(ACTIVE)
  expiresAt        DateTime?
  fulfilledAt      DateTime?
  note             String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  wallet           Wallet           @relation(fields: [walletId], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, expiresAt])
}

// ============================================================================
// INVITE CAMPAIGNS — bulk player acquisition: branded SMS/email invites that
// grant the invitee a bonus when they register with the campaign's code.
// ============================================================================

enum CampaignStatus {
  DRAFT
  SENDING
  SENT
  CANCELLED
}

enum ContactType {
  EMAIL
  PHONE
}

enum InviteEntryStatus {
  QUEUED
  SENT
  DELIVERED
  REGISTERED
  FAILED
  BOUNCED
}

model InviteCampaign {
  id              String         @id // inv_{id}
  code            String         @unique // public invite code embedded in links
  name            String
  bonusAmountTzs  Int
  wagerMultiplier Decimal        @db.Decimal(4, 1)
  expiresInDays   Int
  messageEn       String
  messageSw       String
  status          CampaignStatus @default(DRAFT)
  totalInvites    Int            @default(0)
  totalRegistered Int            @default(0)
  createdById     String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  entries   InviteEntry[]
  createdBy User          @relation(fields: [createdById], references: [id])

  @@index([status])
  @@index([createdById])
}

model InviteEntry {
  id               String            @id // ive_{id}
  campaignId       String
  contactType      ContactType
  contactValue     String // email or +255…
  bonusAmountTzs   Int
  status           InviteEntryStatus @default(QUEUED)
  sentAt           DateTime?
  registeredUserId String?
  bonusGrantId     String?
  failureReason    String?
  createdAt        DateTime          @default(now())

  campaign InviteCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, contactValue])
  @@index([campaignId, status])
