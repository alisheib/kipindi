// Kipindi — database schema
// Sprint 0: comprehensive schema covering KYC, wallet, betting, integrity, compliance.
// Provider: PostgreSQL. Money-handling and concurrency demand transactional integrity.
// All money fields use Decimal(18,2). All TZS amounts in whole units (no fractional shillings).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  PLAYER
  AGENT
  MODERATOR
  ADMIN
  COMPLIANCE
  SUPPORT
}

enum UserStatus {
  ACTIVE
  PENDING_KYC
  SUSPENDED
  SELF_EXCLUDED
  COOLED_OFF
  CLOSED
}

enum Locale {
  EN
  SW
}

enum KycStatus {
  NOT_STARTED
  IN_PROGRESS
  PENDING_REVIEW
  APPROVED
  REJECTED
  ADDITIONAL_INFO_REQUIRED
}

enum KycRejectReason {
  BLURRY_DOC
  DETAILS_MISMATCH
  EXPIRED_ID
  UNDERAGE
  SANCTIONED
  DUPLICATE_IDENTITY
  OTHER
}

enum DocType {
  NIDA
  NIDA_FRONT
  NIDA_BACK
  PASSPORT
  DRIVER_LICENSE
  VOTER_CARD
  SELFIE
}

enum WalletStatus {
  ACTIVE
  FROZEN
  CLOSED
}

enum TxnType {
  DEPOSIT
  WITHDRAWAL
  BET_PLACED
  BET_PAYOUT
  BET_REFUND
  BONUS_CREDIT
  ADJUSTMENT_DEBIT
  ADJUSTMENT_CREDIT
  CASHOUT
  HOUSE_FEE
}

enum TxnStatus {
  PENDING
  PROCESSING
  AML_REVIEW
  CONFIRMED
  FAILED
  REVERSED
  CANCELLED
}

enum PaymentProvider {
  MPESA
  TIGO_PESA
  AIRTEL_MONEY
  HALO_PESA
  MIXX
  TTCL_PESA
  CARD
  BANK_TRANSFER
  INTERNAL
