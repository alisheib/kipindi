// ============================================================================
// SOURCE OF FUNDS — AML declaration (1:1 with User)
// ============================================================================

model SourceOfFunds {
  userId                   String                    @id
  user                     User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  declaredSource           String // salary, business, savings, investments, inheritance, other
  declaredOccupation       String
  declaredEmployer         String?
  declaredAnnualIncomeBand String // under-12m, 12m-50m, 50m-200m, over-200m
  declaredOther            String?
  reviewStatus             SourceOfFundsReviewStatus @default(PENDING)
  reviewerId               String?
  reviewedAt               DateTime?
  submittedAt              DateTime                  @default(now())
}

// ============================================================================
// REFERRAL REWARDS — affiliate payout ledger
// ============================================================================

model ReferralReward {
  id              String               @id @default(cuid())
  referrerUserId  String
  referrerUser    User                 @relation("ReferralRewardsGiven", fields: [referrerUserId], references: [id])
  recruitUserId   String
  recruitUser     User                 @relation("ReferralRewardsReceived", fields: [recruitUserId], references: [id])
  type            ReferralRewardType
  label           String
  amountTzs       Decimal              @db.Decimal(18, 2)
  status          ReferralRewardStatus @default(PENDING)
  recipientUserId String // denormalised — always referrer or recruit
  note            String?
  createdAt       DateTime             @default(now())

  @@index([referrerUserId, createdAt])
  @@index([recruitUserId])
}

// ============================================================================
// PROPOSALS — player-submitted market proposals + voting
// ============================================================================

/// F11 — a player's formal objection to a market's verdict, filed inside the
/// objection window while the pool is still intact and every position is OPEN.
/// An OPEN objection FREEZES that market's settlement (see settleMarket), so this
/// is a money-bearing compliance record: it must survive a restart.
model Objection {
  id              String    @id @default(cuid())
  marketId        String
  market          PredictionMarket @relation(fields: [marketId], references: [id])
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  /// WRONG_OUTCOME | SOURCE_CONTRADICTS | AMBIGUOUS_CRITERION | RESOLVED_EARLY | OTHER
  reason          String
  detail          String    @db.Text
  /// OPEN | UPHELD | REJECTED — only OPEN freezes the money. There is no player
  /// withdraw: a mistaken objection is released by an officer rejecting it.
  status          String    @default("OPEN")
  createdAt       DateTime  @default(now())
  reviewedBy      String?
  reviewedAt      DateTime?
  reviewNote      String?   @db.Text
  /// VOID | REVERSE — what the officer did about an upheld objection.
  remedy          String?
  /// The verdict being disputed, captured at filing so the trail survives a remedy.
  outcomeAtFiling String?

  @@index([status])
  @@index([marketId])
  @@index([userId])
}

model Proposal {
  id                  String         @id @default(cuid())
  proposerId          String
  proposer            User           @relation(fields: [proposerId], references: [id])
  titleEn             String
  titleSw             String?
  titleZh             String?
  description         String?
  resolutionCriterion String
  category            String // sports, macro, weather, crypto, culture, infrastructure
  resolutionDate      String // ISO date YYYY-MM-DD
  // When betting (selection) closes — ISO date YYYY-MM-DD. Optional: if unset, the
  // market's selectionClosedAt is auto-derived at publish. Always <= resolutionDate.
  selectionCloseDate  String?
  sourceUrl           String? // player-supplied trusted source for resolution (required at app layer)
  status              ProposalStatus @default(REVIEW)
  up                  Int            @default(0)
  down                Int            @default(0)
  publishedMarketId   String?
  // Bonus (TZS) granted to the proposer's bonus wallet at APPROVAL. Column kept
  // as prizePaidTzs (@map) to avoid a data migration when the reward model moved
  // from pay-on-resolve to instant-on-approval.
  bonusGrantedTzs     Decimal        @default(0) @db.Decimal(18, 2) @map("prizePaidTzs")
  bonusGrantId        String? // the BonusGrant credited at approval (idempotency/audit trail)
  approvedAt          DateTime?
  declineReason       String?
  declineNote         String?
  changeNote          String?
  reviewedBy          String?
  reviewedAt          DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  votes ProposalVote[]

  @@index([proposerId])
  @@index([status])
}

model ProposalVote {
  id         String        @id @default(cuid())
  proposalId String
  proposal   Proposal      @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  userId     String
  user       User          @relation(fields: [userId], references: [id])
  dir        VoteDirection
  createdAt  DateTime      @default(now())

  @@unique([proposalId, userId])
}

// A player's watchlist ("star") on a market. Drives the closing-soon + settled
// alerts (F3). One row per (user, market); unfollow deletes the row.
model Watchlist {
  id        String           @id @default(cuid())
  marketId  String
  market    PredictionMarket @relation(fields: [marketId], references: [id], onDelete: Cascade)
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())

  @@unique([marketId, userId])
  @@index([userId, createdAt])
}

// A browser web-push subscription (F4). One row per device/endpoint; a player may
// have several. Pruned automatically when the push service reports 404/410 (gone).
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

// ============================================================================
// PREDICTION MARKETS — binary YES/NO pari-mutuel markets
// ============================================================================

model PredictionMarket {
  id                  String                 @id @default(cuid())
  titleEn             String
  titleSw             String
  titleZh             String?
  category            String // sports, macro, weather, crypto, culture, tech, other
  sourceUrl           String
  resolutionCriterion String
  resolutionAt        DateTime
  /** When new bets (selections) stop being accepted. Null = bets close at
   *  resolutionAt (legacy behavior). Always < resolutionAt when set. */
  selectionClosedAt   DateTime?
  status              PredictionMarketStatus @default(DRAFT)
  yesPool             Decimal                @default(0) @db.Decimal(18, 2)
  noPool              Decimal                @default(0) @db.Decimal(18, 2)
  predictorCount      Int                    @default(0)
  /** The fee rates FROZEN onto this poll at creation — commissionRate,
   *  feeCeilingRate, cashOutFeeRate, freeExitGraceMinutes, the TRA/GBT levy
   *  rates and thinProfitRatio. See FeeSnapshot in src/lib/payout.ts.
   *
   *  Settlement, cash-out and every payout preview read THIS, never the live
   *  admin config. Before it existed, settlement read live config, so retuning a
   *  rate in admin silently repriced bets that had ALREADY BEEN PLACED — while
   *  the admin page claimed in writing that it did not. A rate change now affects
   *  future polls only.
   *
   *  Null only on rows created before this column existed; snapshotOrLegacy()
   *  in market-config.ts prices those at the OLD 9% commission plus the NEW
   *  ceiling, which can only ever pay their winners MORE than they were quoted. */
  feeSnapshot         Json?
  resolvedOutcome     String? // YES, NO, VOID
  resolutionStage1By  String?
  resolutionStage1At  DateTime?
  resolutionStage2By  String?
  resolutionStage2At  DateTime?
  objectionsClosedAt  DateTime?
  /** When the money actually moved. `status: RESOLVED` is only the verdict; a
   *  RESOLVED market with settledAt = null has an intact pool and OPEN positions,
   *  and is still inside its objection window. Settlement is gated on that window
   *  elapsing with no objection open — see settleDueMarkets in market-service.ts. */
  settledAt           DateTime?
  /** The officer's recorded evidence excerpt — the exact quote from the official
   *  source that justifies the verdict, captured at stage-1 of the resolution
   *  ceremony (also written immutably to the audit chain). Denormalised here so
   *  the player-facing settlement-proof panel can render it without scanning the
   *  audit log. Capped at 2000 chars at the service layer. Null = none recorded. */
  resolutionEvidence  String?   @db.Text
  /** When officers were alerted this market is closed-by-time + awaiting their
   *  resolution. Set once by the resolution-due sweep (one alert per market). */
  resolutionNotifiedAt DateTime?
  /** When the bettors on this market were notified that selections have closed
   *  and it's awaiting results. Set once by the selection-closed sweep (one
   *  "waiting for results" notification per market). */
  selectionClosedNotifiedAt DateTime?
  /** When WATCHERS were alerted that this market closes within the hour. Set once
   *  by the closing-soon sweep, so a follower is nudged exactly once per market. */
  closingSoonNotifiedAt     DateTime?
  /** AI sentinel recommendation — populated when the sentinel auto-closes this
   *  market. Officers see this pre-filled in the resolver queue. */
  sentinelOutcome      String?   // YES or NO
  sentinelEvidence     String?   @db.Text
  sentinelReasoning    String?   @db.Text
  sentinelSourceUrl    String?
  sentinelConfidence   Int?
  sentinelClosedAt     DateTime?
  proposedBy          String
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  positions  Position[]
  comments   Comment[]
  watchers   Watchlist[]
  objections Objection[]
  snapshots  MarketSnapshot[]

  @@index([status])
  @@index([resolutionAt])
}

/// Point-in-time record of a market's implied YES probability and pool sizes.
///
/// Written on every price-moving event (bet, cash-out, resolution) so the
/// ProbabilityChart on /markets/[id] and the MarketCard sparkline render REAL
/// history that survives a deploy.
///
/// Before this table, history lived in a process-local Map. Because every push
/// to main is a live deploy, that Map was wiped several times a week — which in
/// turn made `seedHistory()` fabricate a synthetic random walk for EVERY market
/// on every detail-page render, violating the A-5 no-fabrication rule the
/// MarketCard cites in its own source. Both the Map and seedHistory are gone.
model MarketSnapshot {
  id       String   @id @default(cuid())
  marketId String
  /// The instant this snapshot was taken.
  t        DateTime @default(now())
  /// Implied YES probability, 0..1 (NOT 0..100 — matches the kit PriceChart shape).
  yes      Float
  /// Pool sizes at this instant. Decimal to match PredictionMarket.yesPool/noPool
  /// exactly; read for display only, never moves money.
  yesPool  Decimal  @db.Decimal(18, 2)
  noPool   Decimal  @db.Decimal(18, 2)
  volume   Decimal  @db.Decimal(18, 2)

  market PredictionMarket @relation(fields: [marketId], references: [id], onDelete: Cascade)

  /// The only access pattern is newest-N points for one market, so this composite
  /// serves both the read and the retention prune. Never query without marketId.
  @@index([marketId, t])
}

model Position {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id])
  marketId        String
  market          PredictionMarket @relation(fields: [marketId], references: [id], onDelete: Cascade)
  side            MarketSide
  stake           Decimal          @db.Decimal(18, 2)
  // Portion of `stake` funded from the bonus wallet (whole TZS). 0 = fully real.
  // Used to split refunds (bonus part returns to bonus on void) and to block
  // cash-out of bonus-funded positions (would otherwise convert bonus → cash).
  bonusStakeTzs   Int              @default(0)
  potentialPayout Decimal          @db.Decimal(18, 2)
  status          PositionStatus   @default(OPEN)
  finalPayout     Decimal?         @db.Decimal(18, 2)
  placedAt        DateTime         @default(now())
  settledAt       DateTime?
  // Client-generated UUID — prevents double-submit on 2G (same key = same intent).
  // Nullable: positions created by internal flows (settlement adjustments) don't carry one.
  idempotencyKey  String?          @unique

  @@index([userId, marketId])
  @@index([marketId, status])
}

// ============================================================================
// AI PIPELINE — candidates + polls
// ============================================================================

model MarketCandidate {
  id                  String         @id @default(cuid())
  state               CandidateState @default(EXTRACTED)
  category            String
  proposedTitleEn     String
  proposedTitleSw     String?
  proposedTitleZh     String?
  resolutionCriterion String
  resolutionAt        DateTime
  sources             Json // Array<{ url, publisher, publishedAt?, retrievedAt }>
  confidence          Int            @default(0)
  rejectReason        String?
  rejectNote          String?
  trace               Json // Array<{ layer, outcome, at }>
  reviewedBy          String?
  reviewedAt          DateTime?
  reviewNote          String?
  publishedMarketId   String?
  tokensSpent         Int            @default(0)
  costUsd             Decimal        @default(0) @db.Decimal(10, 6)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([state])
}

model AIPoll {
  id                   String      @id @default(cuid())
  state                AIPollState @default(GENERATING)
  requestCategory      String
  requestPrompt        String      @db.Text
  generation           Json? // AIPollGeneration object
  rawResponse          String?     @db.Text
  filterReasons        Json        @default("[]")
  qualityIndicators    Json        @default("[]")
  overallQuality       Int         @default(0)
  titleEn              String
  titleSw              String
  titleZh              String?
  category             String
  resolutionCriterion  String
  resolutionAt         DateTime
  selectionClosedAt    DateTime?
  options              Json        @default("[]")
  sources              Json        @default("[]")
  confidence           Int         @default(0)
  reasoning            String      @db.Text
  reviewedBy           String?
  reviewedAt           DateTime?
  reviewNote           String?
  rejectReasons        Json        @default("[]")
  publishedMarketId    String?
  publishedCandidateId String?
  tokensUsed           Int         @default(0)
  costUsd              Decimal     @default(0) @db.Decimal(10, 6)
  latencyMs            Int         @default(0)
  regenerationOf       String?
  regenerationCount    Int         @default(0)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  @@index([state])
}

// ============================================================================
// MARKET COMMENTS — discussion threads on prediction markets
// ============================================================================

model Comment {
  id         String           @id @default(cuid())
  marketId   String
  market     PredictionMarket @relation(fields: [marketId], references: [id], onDelete: Cascade)
  userId     String
  user       User             @relation(fields: [userId], references: [id])
  authorName String
  body       String
  side       String? // YES, NO, or null
  reports    Json             @default("[]") // userId[] who reported
  hidden     Boolean          @default(false)
  deleted    Boolean          @default(false)
  createdAt  DateTime         @default(now())

  @@index([marketId, createdAt])
}

// ============================================================================
// HOUSE LIQUIDITY POOL — ledger entries
// ============================================================================

model HousePoolLedger {
  id           String             @id @default(cuid())
  type         HousePoolEntryType
  amount       Decimal            @db.Decimal(18, 2)
  balanceAfter Decimal            @db.Decimal(18, 2)
  marketId     String?
  note         String
  actorId      String
  createdAt    DateTime           @default(now())

  @@index([createdAt])
}

// ============================================================================
// TRUSTED SOURCES — AI pipeline source registry
// ============================================================================

model TrustedSource {
  id        String   @id @default(cuid())
  domain    String
  label     String
  category  String // MarketCategory value
  rationale String
  enabled   Boolean  @default(true)
  addedBy   String
  addedAt   DateTime @default(now())

  @@index([domain])
}

// ============================================================================
// EVENT CALENDAR (F8) — real-world moments to schedule markets around.
//
// OPERATOR-AUTHORED, NEVER AI-AUTHORED. We have no fixtures feed (no Sportradar),
// so if the model invented the calendar it would be inventing real-world events
// and dates on a licensed real-money product. An officer enters each event with an
// official source URL, which is validated against the TrustedSource allowlist for
// its category. The AI is only ever STEERED by an event an officer already vouched
// for — it never authors one.
// ============================================================================
model EventCalendar {
  id          String   @id @default(cuid())
  /** What happens, in plain English. e.g. "Simba SC vs Yanga — Kariakoo Derby". */
  title       String
  category    String // MarketCategory value
  /** When the real-world event occurs (drives the market's resolution timing). */
  startsAt    DateTime
  /** Official, verifiable source for the event — must pass isSourceTrusted(). */
  sourceUrl   String
  /** Optional operator note steering what kind of market to draft. */
  note        String?
  /** Set once a market/poll has been generated for this event (no duplicates). */
  generatedAt DateTime?
  /** The AI poll drafted from this event, if any. */
  aiPollId    String?
  addedBy     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([startsAt])
  @@index([category, startsAt])
}

// ============================================================================
// TOTP — admin 2FA secrets (1:1 with User)
// ============================================================================

model TotpSecret {
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  secret    String
  createdAt DateTime @default(now())
}

// One-time 2FA recovery codes. Stored HMAC-hashed (never plaintext); a code is
// consumed exactly once (usedAt stamped) when a player logs in without their
// authenticator. Regenerated as a set on enrollment / manual regenerate.
model TotpBackupCode {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([userId, codeHash])
}

// ============================================================================
// SYSTEM CONFIG — durable key/value store for admin-tunable settings that were
// previously globalThis-only (market fee/stake config, house-pool balance+seeds,
// affiliate/proposals/ai-poll config, disabled market categories). Each module
// owns one or more keys; the value is the module's config object as JSON. These
// reset to code defaults on every deploy unless persisted here.
// ============================================================================

model SystemConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// Single-active-session registry. One row per user = their ONE valid session.
// A new login overwrites it (revoking prior devices); logout/suspend/self-
// exclude delete it. Durable so the single-session invariant + server-side
// revocation survive deploys (was globalThis-only → lost on every restart).
// No FK to User on purpose: this must never fail to write or cascade-delete.
model ActiveSession {
  userId    String   @id
  sessionId String
  updatedAt DateTime @updatedAt
}

// Per-call AI usage ledger — one row per Claude API call (poll generation, the
// help chatbot, the market sentinel). Powers the admin AI-usage page: exact
// time, model, token counts, web searches, cost, and success/error for every
// call, with the indexes needed for paginated, filtered, time-ranged views.
model AiUsageEvent {
  id           String   @id
  createdAt    DateTime @default(now())
  feature      String   // "polls" | "chat" | "sentinel" | "other"
  model        String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  webSearches  Int      @default(0)
  costUsd      Float    @default(0)
  ok           Boolean  @default(true)
  errorType    String?
  latencyMs    Int?
  detail       String?  // optional context, e.g. market title / poll category

  @@index([createdAt])
  @@index([feature, createdAt])
  @@index([ok, createdAt])
}

// ============================================================================
// DOUBLE-ENTRY LEDGER — every money movement as balanced debit/credit pairs.
// The existing Transaction table (gross flows) is untouched. This table runs
// alongside it (dual-write) to provide regulator-grade accounting: every TZS
// that enters, leaves, or moves within the platform is accounted for across
// virtual accounts. Invariant: SUM(amount) across all entries in a group = 0.
// ============================================================================

model LedgerEntry {
  id        String        @id @default(cuid())
  groupId   String        // groups balanced entries (e.g. txn_xxx or settle_xxx)
  account   String        // virtual account: PLAYER:{userId}, HOUSE:TAX, HOUSE:COMMISSION, etc.
  entryType LedgerEntryType
  amount    Decimal       @db.Decimal(18, 2) // positive = credit to account, negative = debit
  currency  String        @default("TZS")
  memo      String?       // human-readable context
  txnId     String?       // soft ref to Transaction.id (nullable for non-txn entries)
  marketId  String?       // soft ref to market (for settlement entries)
  userId    String?       // soft ref to user (for player-account entries)
  createdAt DateTime      @default(now())

  @@index([groupId])
  @@index([account, createdAt])
  @@index([txnId])
  @@index([marketId])
  @@index([entryType, createdAt])
  @@index([userId]) // audit M3 — per-user ledger scans (trial balance / C3)
}

enum LedgerEntryType {
  DEPOSIT                // External money in → player account
  WITHDRAWAL             // Player account → external money out
  WITHDRAWAL_FEE         // Withdrawal fee (1%) → payment gateway + operator
  STAKE_DEBIT            // Player account → market pool (bet placed)
  PAYOUT_CREDIT          // Market pool → player account (bet won)
  SETTLEMENT_COMMISSION  // Market pool → operator revenue (the capped fee)
  SETTLEMENT_TRA_LEVY    // Operator commission → TRA (tax on commission)
  SETTLEMENT_GBT_LEVY    // Operator commission → GBT (gaming board levy)
  REFUND                 // Market pool → player account (void/refund)
  BONUS_CREDIT           // Bonus → real balance (wagering met)
  BONUS_GRANT            // System → bonus account (promotional credit)
  BONUS_SPEND            // Bonus account → market pool (bet with bonus)
  BONUS_EXPIRE           // Bonus account → void (expired grant)
  BONUS_REFUND           // Market pool → bonus account (void refund to bonus)
  CASHOUT                // Market pool → player account (early exit)
  CASHOUT_FEE            // Early-exit fee → operator revenue. Goes to the HOUSE.
  ADJUSTMENT             // Admin adjustment (credit or debit)
  INTERNAL_CREDIT        // Internal credit (affiliate reward, proposal prize)

  // ── Retired 2026-07 with the tax/reserve/aggregator rates ────────────────
  // Never written again. Kept because historical LedgerEntry rows reference
  // them and the books must continue to reconcile — dropping an enum value
  // that existing rows use would break the migration and orphan real money.
  WITHDRAWAL_TAX         // DEAD. Was the 15% withholding tax on every withdrawal.
  SETTLEMENT_TAX         // DEAD. Was taxRate × pool.
  SETTLEMENT_RESERVE     // DEAD. Was reserveRate × pool.
  SETTLEMENT_AGGREGATOR  // DEAD. Was aggregatorRate × pool.
}
