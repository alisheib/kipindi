// ============================================================================
// RESPONSIBLE GAMBLING
// ============================================================================

model ResponsibleGambling {
  id                         String    @id @default(cuid())
  userId                     String    @unique
  user                       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyDepositLimit          Decimal?  @db.Decimal(18, 2)
  weeklyDepositLimit         Decimal?  @db.Decimal(18, 2)
  monthlyDepositLimit        Decimal?  @db.Decimal(18, 2)
  dailyLossLimit             Decimal?  @db.Decimal(18, 2)
  weeklyLossLimit            Decimal?  @db.Decimal(18, 2)
  sessionTimeLimitMin        Int?
  realityCheckIntervalMin    Int       @default(30)
  selfExclusionUntil         DateTime?
  coolingOffUntil            DateTime?
  /// When the CURRENT self-exclusion / cooling-off period actually began.
  ///
  /// The cross-operator register must state when an exclusion started, not when the
  /// account was opened. Before these columns the register printed `User.createdAt`
  /// in its "Started" column — wrong for every row, and inconsistent with the
  /// "days remaining" beside it, which was derived from the (correct) end date.
  ///
  /// Nullable and not backfilled: for exclusions set before this existed we do not
  /// know the start, and the register prints "—" rather than inventing one.
  selfExclusionStartedAt     DateTime?
  coolingOffStartedAt        DateTime?
  pendingIncreaseTo          Decimal?  @db.Decimal(18, 2)
  pendingIncreaseEffectiveAt DateTime?
  pendingWeeklyIncreaseTo          Decimal?  @db.Decimal(18, 2)
  pendingWeeklyIncreaseEffectiveAt DateTime?
  pendingMonthlyIncreaseTo          Decimal?  @db.Decimal(18, 2)
  pendingMonthlyIncreaseEffectiveAt DateTime?
  updatedAt                  DateTime  @updatedAt
  createdAt                  DateTime  @default(now())
}

// ============================================================================
// NOTIFICATIONS
// ============================================================================

model Notification {
  id            String               @id @default(cuid())
  userId        String
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel       NotificationChannel
  priority      NotificationPriority @default(NORMAL)
  event         String // e.g. "bet.won", "kyc.approved"
  kind          String? // WIN, LOSS, BET_PLACED, ROUND_RESULT, etc.
  href          String?
  titleEn       String?
  titleSw       String?
  titleZh       String?
  bodyEn        String
  bodySw        String
  bodyZh        String?
  payload       Json?
  sentAt        DateTime?
  readAt        DateTime?
  dismissedAt   DateTime?
  failedAt      DateTime?
  failureReason String?
  createdAt     DateTime             @default(now())

  @@index([userId, readAt])
  @@index([channel, sentAt])
}

// ============================================================================
// AUDIT LOG (append-only)
// ============================================================================

model AuditLog {
  id         String        @id @default(cuid())
  category   AuditCategory
  action     String // verb-noun: "user.login", "bet.placed", "kyc.approved"
  // No FK to User on purpose: an append-only audit log must never fail to write
  // (or be cascade-deleted) because the actor row is missing or was erased under
  // a GDPR/DSAR request. actorId is a plain indexed string.
  actorId    String?
  targetType String?
  targetId   String?
  payload    Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime      @default(now())
  // Monotonic insertion counter (BIGSERIAL). Used only to find the chain tail in
  // O(log n) — selectHead() reads the greatest seq and confirms it is a true tail
  // (audit C6). Never the source of truth for chain ORDER; the prevHash links are.
  seq        BigInt        @unique @default(autoincrement())
  // HMAC chain: prevHash links to the previous entry's entryHash ("GENESIS" for
  // the first); entryHash is the HMAC over the row. Together they make the table
  // tamper-evident — any deletion or in-place edit breaks the chain on verify.
  // @@unique([prevHash]) makes the chain physically fork-proof: two entries can
  // never share a predecessor, so multi-instance appends can't diverge (C6).
  prevHash   String        @default("GENESIS")
  entryHash  String        @unique

  @@unique([prevHash])
  @@index([category, createdAt])
  @@index([actorId, createdAt])
  @@index([targetType, targetId])
}

// ============================================================================
// AGENT / AFFILIATE PROGRAM
// ============================================================================

model AffiliateAgent {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code            String   @unique
  tier            String   @default("STANDARD")
  commissionPct   Decimal  @default(5.00) @db.Decimal(5, 2)
  totalRecruits   Int      @default(0)
  totalCommission Decimal  @default(0) @db.Decimal(18, 2)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  recruits User[] @relation("AgentRecruits")
}

// ============================================================================
// SYSTEM HEALTH (provider health, used by admin analytics)
// ============================================================================

model ProviderHealth {
  id           String          @id @default(cuid())
  provider     PaymentProvider
  bucketStart  DateTime
  successCount Int             @default(0)
  failureCount Int             @default(0)
  p50LatencyMs Int?
  p95LatencyMs Int?

  @@unique([provider, bucketStart])
  @@index([provider, bucketStart])
}

