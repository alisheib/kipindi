// Kipindi — database schema
// Sprint 0: comprehensive schema covering KYC, wallet, betting, integrity, compliance.
// Provider: PostgreSQL. Money-handling and concurrency demand transactional integrity.
// All money fields use Decimal(18,2). All TZS amounts in whole units (no fractional shillings).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  PLAYER
  AGENT
  MODERATOR
  ADMIN
  COMPLIANCE
  SUPPORT
}

enum UserStatus {
  ACTIVE
  PENDING_KYC
  SUSPENDED
  SELF_EXCLUDED
  COOLED_OFF
  CLOSED
}

enum Locale {
  EN
  SW
}

enum KycStatus {
  NOT_STARTED
  IN_PROGRESS
  PENDING_REVIEW
  APPROVED
  REJECTED
  ADDITIONAL_INFO_REQUIRED
}

enum KycRejectReason {
  BLURRY_DOC
  DETAILS_MISMATCH
  EXPIRED_ID
  UNDERAGE
  SANCTIONED
  DUPLICATE_IDENTITY
  OTHER
}

enum DocType {
  NIDA
  PASSPORT
  DRIVER_LICENSE
  VOTER_CARD
  SELFIE
}

enum WalletStatus {
  ACTIVE
  FROZEN
  CLOSED
}

enum TxnType {
  DEPOSIT
  WITHDRAWAL
  BET_PLACED
  BET_PAYOUT
  BET_REFUND
  BONUS_CREDIT
  ADJUSTMENT_DEBIT
  ADJUSTMENT_CREDIT
  CASHOUT
  HOUSE_FEE
}

enum TxnStatus {
  PENDING
  PROCESSING
  AML_REVIEW
  CONFIRMED
  FAILED
  REVERSED
  CANCELLED
}

enum PaymentProvider {
  MPESA
  TIGO_PESA
  AIRTEL_MONEY
  HALO_PESA
  MIXX
  TTCL_PESA
  CARD
  BANK_TRANSFER
  INTERNAL
}

enum MatchStatus {
  SCHEDULED
  PRE_MATCH
  LIVE
  HALFTIME
  FINISHED
  POSTPONED
  CANCELLED
  ABANDONED
}

enum WindowKind {
  W_0_15
  W_15_30
  W_30_45
  W_45_60
  W_FT
}

enum WindowStatus {
  OPEN
  CLOSED
  SETTLING
  SETTLED
  VOID
}

enum BetOutcome {
  HOME_WIN
  AWAY_WIN
  DRAW
}

enum BetStatus {
  PENDING_CONFIRMATION
  PLACED
  WON
  LOST
  VOIDED
  CASHED_OUT
  PARTIALLY_SETTLED
}

enum FlagType {
  MULTI_ACCOUNT
  IP_OVERLAP
  DEVICE_OVERLAP
  STAKE_PATTERN
  COLLUSION_RING
  VELOCITY
  WASH_TRADE
  MATCH_FIXING_SUSPECT
  CHARGEBACK
}

enum FlagSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FlagStatus {
  OPEN
  REVIEWING
  CONFIRMED
  DISMISSED
}

enum NotificationChannel {
  IN_APP
  PUSH
  SMS
  EMAIL
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum AuditCategory {
  AUTH
  KYC
  WALLET
  BET
  ADMIN
  COMPLIANCE
  SECURITY
  SYSTEM
}

// ============================================================================
// PERSISTENCE — single-row snapshot of the in-memory runtime store
// ============================================================================
//
// The app is single-instance + in-memory by design (Sprint 0–47). To make
// player accounts and money survive a Railway container restart, every
// scheduled backup writes the full HMAC-signed snapshot envelope into
// this row. On boot, the app reads it back and rehydrates globalThis.
//
// Long-term we move every entity to its own first-class Prisma model.
// This row buys us correctness today without that risk.
model StoreSnapshot {
  id        Int      @id @default(1)
  envelope  String   @db.Text   // HMAC-signed JSON envelope; same shape as the disk file
  updatedAt DateTime @updatedAt
}

// ============================================================================
// IDENTITY & ACCESS
// ============================================================================

model User {
  id            String      @id @default(cuid())
  phoneE164     String      @unique
  email         String?     @unique
  passwordHash  String?
  role          UserRole    @default(PLAYER)
  status        UserStatus  @default(PENDING_KYC)
  locale        Locale      @default(SW)
  displayName   String?
  dob           DateTime?
  region        String?
  acceptedTermsVersion String?
  acceptedTermsAt      DateTime?
  marketingOptIn Boolean    @default(false)
  twoFactorEnabled Boolean  @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  lastLoginAt   DateTime?
  closedAt      DateTime?

  wallet        Wallet?
  kycSubmissions KycSubmission[]
  bets          Bet[]
  transactions  Transaction[]
  sessions      Session[]
  otps          Otp[]
  devices       Device[]
  flags         AntiFraudFlag[] @relation("FlaggedUser")
  reviewedFlags AntiFraudFlag[] @relation("FlagReviewer")
  responsibleGambling ResponsibleGambling?
  notifications Notification[]
  auditEntries  AuditLog[]      @relation("AuditActor")
  affiliateAgent AffiliateAgent?
  recruitedBy   String?
  recruitedById AffiliateAgent? @relation("AgentRecruits", fields: [recruitedBy], references: [userId])

  @@index([role, status])
  @@index([createdAt])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash    String   @unique
  ip           String?
  userAgent    String?
  deviceId     String?
  device       Device?  @relation(fields: [deviceId], references: [id])
  createdAt    DateTime @default(now())
  expiresAt    DateTime
  revokedAt    DateTime?
  lastActiveAt DateTime @default(now())

  @@index([userId, revokedAt])
}

model Otp {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  phoneE164  String
  codeHash   String
  purpose    String   // login, register, withdraw, reauth, password_reset
  attempts   Int      @default(0)
  consumedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([phoneE164, purpose])
  @@index([expiresAt])
}

model Device {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fingerprint   String
  platform      String?  // ios, android, web
  model         String?
  osVersion     String?
  appVersion    String?
  pushToken     String?
  firstSeenAt   DateTime @default(now())
  lastSeenAt    DateTime @default(now())
  trustedAt     DateTime?
  blockedAt     DateTime?

  sessions      Session[]

  @@unique([userId, fingerprint])
  @@index([fingerprint])
}

// ============================================================================
// KYC / AML
// ============================================================================

model KycSubmission {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status          KycStatus   @default(IN_PROGRESS)
  rejectReason    KycRejectReason?
  rejectNote      String?
  nidaNumber      String?
  nidaVerifiedAt  DateTime?
  fullName        String?
  dob             DateTime?
  gender          String?
  reviewerId      String?
  reviewedAt      DateTime?
  submittedAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  documents       KycDocument[]

  @@index([userId, status])
  @@index([status, submittedAt])
}

model KycDocument {
  id              String        @id @default(cuid())
  submissionId    String
  submission      KycSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  docType         DocType
  storageKey      String        // object storage key — never store binaries in DB
  mimeType        String
  sizeBytes       Int
  uploadedAt      DateTime      @default(now())
  blurScore       Float?
  ocrText         String?
  rejected        Boolean       @default(false)
  rejectReason    String?
}

// ============================================================================
// WALLET & TRANSACTIONS
// ============================================================================

model Wallet {
  id            String       @id @default(cuid())
  userId        String       @unique
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  status        WalletStatus @default(ACTIVE)
  balance       Decimal      @default(0) @db.Decimal(18, 2)
  pending       Decimal      @default(0) @db.Decimal(18, 2)
  hold          Decimal      @default(0) @db.Decimal(18, 2)
  currency      String       @default("TZS")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  transactions  Transaction[]

  @@index([status])
}

model Transaction {
  id              String          @id @default(cuid())
  walletId        String
  wallet          Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            TxnType
  status          TxnStatus       @default(PENDING)
  amount          Decimal         @db.Decimal(18, 2)
  fee             Decimal         @default(0) @db.Decimal(18, 2)
  taxWithheld     Decimal         @default(0) @db.Decimal(18, 2)
  balanceAfter    Decimal?        @db.Decimal(18, 2)
  currency        String          @default("TZS")
  provider        PaymentProvider?
  providerRef     String?
  providerStatus  String?
  msisdn          String?         // recipient/sender phone for mobile money
  description     String?
  betId           String?
  bet             Bet?            @relation(fields: [betId], references: [id])
  amlReviewedById String?
  amlReviewedAt   DateTime?
  amlReason       String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  completedAt     DateTime?

  @@index([userId, createdAt])
  @@index([walletId, createdAt])
  @@index([type, status])
  @@index([providerRef])
}

// ============================================================================
// MATCHES, WINDOWS, POOLS, BETS
// ============================================================================

model Sport {
  id          String  @id @default(cuid())
  slug        String  @unique
  nameEn      String
  nameSw      String
  active      Boolean @default(true)
  leagues     League[]
}

model League {
  id          String  @id @default(cuid())
  sportId     String
  sport       Sport   @relation(fields: [sportId], references: [id])
  externalId  String?
  slug        String  @unique
  nameEn      String
  nameSw      String
  country     String?
  active      Boolean @default(true)
  matches     Match[]
}

model Team {
  id          String  @id @default(cuid())
  externalId  String? @unique
  slug        String  @unique
  nameEn      String
  nameSw      String?
  shortName   String?
  badgeUrl    String?
  country     String?

  homeMatches Match[] @relation("HomeTeam")
  awayMatches Match[] @relation("AwayTeam")
}

model Match {
  id          String      @id @default(cuid())
  leagueId    String
  league      League      @relation(fields: [leagueId], references: [id])
  externalId  String?     @unique
  homeTeamId  String
  homeTeam    Team        @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId  String
  awayTeam    Team        @relation("AwayTeam", fields: [awayTeamId], references: [id])
  kickoffAt   DateTime
  status      MatchStatus @default(SCHEDULED)
  homeScore   Int         @default(0)
  awayScore   Int         @default(0)
  minute      Int?
  venue       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  windows     Window[]
  events      MatchEvent[]

  @@index([status, kickoffAt])
  @@index([leagueId, kickoffAt])
}

model MatchEvent {
  id        String   @id @default(cuid())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  minute    Int
  type      String   // GOAL, YELLOW, RED, SUB, CORNER, etc.
  team      String?  // home / away
  player    String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([matchId, minute])
}

model Window {
  id            String        @id @default(cuid())
  matchId       String
  match         Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)
  kind          WindowKind
  status        WindowStatus  @default(OPEN)
  closesAt      DateTime
  settledAt     DateTime?
  homeScoreStart Int?
  awayScoreStart Int?
  homeScoreEnd   Int?
  awayScoreEnd   Int?
  resolvedOutcome BetOutcome?
  voidReason     String?
  minStake      Decimal       @default(100)   @db.Decimal(18, 2)
  maxStake      Decimal       @default(500000) @db.Decimal(18, 2)

  pool          Pool?
  bets          Bet[]

  @@unique([matchId, kind])
  @@index([status, closesAt])
}

model Pool {
  id              String   @id @default(cuid())
  windowId        String   @unique
  window          Window   @relation(fields: [windowId], references: [id], onDelete: Cascade)
  totalStake      Decimal  @default(0) @db.Decimal(18, 2)
  homeStake       Decimal  @default(0) @db.Decimal(18, 2)
  awayStake       Decimal  @default(0) @db.Decimal(18, 2)
  drawStake       Decimal  @default(0) @db.Decimal(18, 2)
  housePct        Decimal  @default(15.00) @db.Decimal(5, 2)  // configurable; spec proposes 15-20%
  payoutPct       Decimal  @default(85.00) @db.Decimal(5, 2)
  betCount        Int      @default(0)
  seededAmount    Decimal  @default(0) @db.Decimal(18, 2)     // house liquidity seed
  finalHouseTake  Decimal? @db.Decimal(18, 2)
  finalPayoutPool Decimal? @db.Decimal(18, 2)
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}

model BetBundle {
  id            String     @id @default(cuid())
  userId        String
  totalStake    Decimal    @db.Decimal(18, 2)
  potentialReturn Decimal? @db.Decimal(18, 2)
  bonusMultiplier Decimal  @default(1.00) @db.Decimal(6, 3)
  status        BetStatus  @default(PENDING_CONFIRMATION)
  legs          Bet[]
  placedAt      DateTime   @default(now())
  settledAt     DateTime?

  @@index([userId, placedAt])
}

model Bet {
  id              String     @id @default(cuid())
  userId          String
  user            User       @relation(fields: [userId], references: [id])
  windowId        String
  window          Window     @relation(fields: [windowId], references: [id])
  bundleId        String?
  bundle          BetBundle? @relation(fields: [bundleId], references: [id])
  outcome         BetOutcome
  stake           Decimal    @db.Decimal(18, 2)
  potentialReturn Decimal?   @db.Decimal(18, 2)
  poolShareAtPlacement Decimal? @db.Decimal(8, 5)
  status          BetStatus  @default(PENDING_CONFIRMATION)
  returnAmount    Decimal?   @db.Decimal(18, 2)
  cashedOutAt     DateTime?
  cashedOutValue  Decimal?   @db.Decimal(18, 2)
  placedAt        DateTime   @default(now())
  settledAt       DateTime?
  voidedAt        DateTime?
  voidReason      String?

  transactions    Transaction[]

  @@index([userId, placedAt])
  @@index([windowId, status])
  @@index([status, settledAt])
}

// ============================================================================
// ANTI-FRAUD & INTEGRITY
// ============================================================================

model AntiFraudFlag {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation("FlaggedUser", fields: [userId], references: [id])
  type         FlagType
  severity     FlagSeverity
  status       FlagStatus   @default(OPEN)
  riskScore    Float?
  description  String
  evidence     Json?
  matchId      String?
  windowId     String?
  reviewerId   String?
  reviewer     User?        @relation("FlagReviewer", fields: [reviewerId], references: [id])
  reviewedAt   DateTime?
  resolution   String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([userId, status])
  @@index([type, severity, status])
}

model MatchIntegrityCheck {
  id           String   @id @default(cuid())
  matchId      String
  windowId     String?
  anomalyType  String
  anomalyScore Float
  evidence     Json
  reviewed     Boolean  @default(false)
  reviewerId   String?
  reviewedAt   DateTime?
  notes        String?
  createdAt    DateTime @default(now())

  @@index([matchId, createdAt])
}

// ============================================================================
// RESPONSIBLE GAMBLING
// ============================================================================

model ResponsibleGambling {
  id                   String    @id @default(cuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyDepositLimit    Decimal?  @db.Decimal(18, 2)
  weeklyDepositLimit   Decimal?  @db.Decimal(18, 2)
  monthlyDepositLimit  Decimal?  @db.Decimal(18, 2)
  dailyLossLimit       Decimal?  @db.Decimal(18, 2)
  weeklyLossLimit      Decimal?  @db.Decimal(18, 2)
  sessionTimeLimitMin  Int?
  realityCheckIntervalMin Int    @default(30)
  selfExclusionUntil   DateTime?
  coolingOffUntil      DateTime?
  pendingIncreaseTo    Decimal?  @db.Decimal(18, 2)
  pendingIncreaseEffectiveAt DateTime?
  updatedAt            DateTime  @updatedAt
  createdAt            DateTime  @default(now())
}

// ============================================================================
// NOTIFICATIONS
// ============================================================================

model Notification {
  id          String                @id @default(cuid())
  userId      String
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel     NotificationChannel
  priority    NotificationPriority  @default(NORMAL)
  event       String                // e.g. "bet.won", "kyc.approved"
  titleEn     String?
  titleSw     String?
  bodyEn      String
  bodySw      String
  payload     Json?
  sentAt      DateTime?
  readAt      DateTime?
  failedAt    DateTime?
  failureReason String?
  createdAt   DateTime              @default(now())

  @@index([userId, readAt])
  @@index([channel, sentAt])
}

// ============================================================================
// AUDIT LOG (append-only)
// ============================================================================

model AuditLog {
  id           String        @id @default(cuid())
  category     AuditCategory
  action       String        // verb-noun: "user.login", "bet.placed", "kyc.approved"
  actorId      String?
  actor        User?         @relation("AuditActor", fields: [actorId], references: [id])
  targetType   String?
  targetId     String?
  payload      Json?
  ip           String?
  userAgent    String?
  createdAt    DateTime      @default(now())

  @@index([category, createdAt])
  @@index([actorId, createdAt])
  @@index([targetType, targetId])
}

// ============================================================================
// AGENT / AFFILIATE PROGRAM
// ============================================================================

model AffiliateAgent {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code            String   @unique
  tier            String   @default("STANDARD")
  commissionPct   Decimal  @default(5.00) @db.Decimal(5, 2)
  totalRecruits   Int      @default(0)
  totalCommission Decimal  @default(0) @db.Decimal(18, 2)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  recruits        User[]   @relation("AgentRecruits")
}

// ============================================================================
// SYSTEM HEALTH (provider health, used by admin analytics)
// ============================================================================

model ProviderHealth {
  id          String          @id @default(cuid())
  provider    PaymentProvider
  bucketStart DateTime
  successCount Int            @default(0)
  failureCount Int            @default(0)
  p50LatencyMs Int?
  p95LatencyMs Int?

  @@unique([provider, bucketStart])
  @@index([provider, bucketStart])
}
