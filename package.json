{
  "name": "fiftypick",
  "version": "0.1.0",
  "private": true,
  "description": "Licensed pool-based time-window sports betting platform — Tanzania first.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "prisma migrate deploy && next start",
    "postinstall": "prisma generate",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:date": "tsx scripts/date-mask.test.mts",
    "test:audit": "tsx scripts/audit-chain.test.mts",
    "test:wallet": "tsx scripts/wallet-atomic.test.mts",
    "test:payments": "tsx scripts/payment-webhook.test.mts",
    "test:config": "tsx scripts/config-persist.test.mts",
    "test:kyc": "tsx scripts/kyc-review.test.mts && tsx scripts/kyc-submit-notify.test.mts && tsx scripts/kyc-flow-stress.test.mts && tsx scripts/kyc-security.test.mts",
    "qa:live": "node scripts/pre-deploy-live-check.mjs",
    "predeploy": "npm run typecheck && npm run test:date && npm run test:audit && npm run test:wallet && npm run test:payments && npm run test:config && npm run test:kyc && npm run build && npm run qa:live",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "@next/swc-wasm-nodejs": "^16.2.4",
    "@prisma/client": "^6.5.0",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "lucide-react": "^0.468.0",
    "next": "^16.0.0",
    "next-themes": "^0.4.4",
    "pdfkit": "^0.18.0",
    "postmark": "^4.0.7",
    "prisma": "^6.5.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "autoprefixer": "^10.4.20",
    "playwright": "^1.50.0",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  }
}
