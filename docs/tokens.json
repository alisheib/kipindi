  "typography": {
    "family": {
      "display": "\"Sora\", \"Inter\", \"Helvetica Neue\", Arial, sans-serif",
      "body":    "\"Inter\", \"Helvetica Neue\", Arial, \"Noto Sans\", sans-serif",
      "mono":    "\"JetBrains Mono\", \"SF Mono\", Menlo, Consolas, monospace"
    },
    "weight": {
      "regular": 400,
      "medium":  500,
      "semibold":600,
      "bold":    700
    },
    "scale": {
      "micro":     { "size": 10, "lineHeight": 14, "letterSpacing": 0.4,  "weight": 500 },
      "caption":   { "size": 12, "lineHeight": 16, "letterSpacing": 0.2,  "weight": 500 },
      "label":     { "size": 13, "lineHeight": 18, "letterSpacing": 0.1,  "weight": 500 },
      "body-sm":   { "size": 14, "lineHeight": 20, "letterSpacing": 0,    "weight": 400 },
      "body":      { "size": 16, "lineHeight": 24, "letterSpacing": 0,    "weight": 400 },
      "body-lg":   { "size": 18, "lineHeight": 28, "letterSpacing": 0,    "weight": 400 },
      "title-sm":  { "size": 20, "lineHeight": 28, "letterSpacing": -0.1, "weight": 600 },
      "title-md":  { "size": 24, "lineHeight": 32, "letterSpacing": -0.2, "weight": 600 },
      "title-lg":  { "size": 30, "lineHeight": 38, "letterSpacing": -0.3, "weight": 600 },
      "display-3": { "size": 36, "lineHeight": 44, "letterSpacing": -0.4, "weight": 700 },
      "display-2": { "size": 48, "lineHeight": 56, "letterSpacing": -0.6, "weight": 700 },
      "display-1": { "size": 64, "lineHeight": 72, "letterSpacing": -0.8, "weight": 700 }
    },
    "features": {
      "tabular":  "\"tnum\" 1, \"lnum\" 1",
      "lining":   "\"lnum\" 1",
      "stylistic":"\"ss01\" 1"
    }
  },
  "space": {
    "0": 0, "1": 2, "2": 4, "3": 8, "4": 12, "5": 16,
    "6": 20, "7": 24, "8": 32, "9": 40, "10": 48, "11": 64, "12": 80, "13": 96, "14": 128
  },
  "size": {
    "icon":   { "sm": 16, "md": 20, "lg": 24, "xl": 32 },
    "avatar": { "xs": 20, "sm": 24, "md": 32, "lg": 40, "xl": 56 },
    "button": { "sm": 32, "md": 40, "lg": 48, "xl": 56 },
    "touchTarget": 44
  },
  "radius": {
    "none": 0, "xs": 2, "sm": 4, "md": 8, "lg": 12, "xl": 16, "2xl": 24, "pill": 999
  },
  "shadow": {
    "light": {
      "0": "none",
      "1": "0 1px 2px rgba(10,24,56,0.06), 0 1px 1px rgba(10,24,56,0.04)",
      "2": "0 2px 6px rgba(10,24,56,0.08), 0 1px 2px rgba(10,24,56,0.04)",
      "3": "0 6px 16px rgba(10,24,56,0.10), 0 2px 4px rgba(10,24,56,0.06)",
      "4": "0 12px 28px rgba(10,24,56,0.14), 0 4px 8px rgba(10,24,56,0.08)",
      "5": "0 24px 48px rgba(10,24,56,0.18), 0 8px 16px rgba(10,24,56,0.10)"
    },
    "dark": {
      "0": "none",
      "1": "0 1px 2px rgba(0,0,0,0.40), inset 0 1px 0 rgba(255,255,255,0.04)",
      "2": "0 2px 6px rgba(0,0,0,0.50), inset 0 1px 0 rgba(255,255,255,0.04)",
      "3": "0 6px 16px rgba(0,0,0,0.55), inset 0 1px 0 rgba(255,255,255,0.05)",
      "4": "0 12px 28px rgba(0,0,0,0.65), inset 0 1px 0 rgba(255,255,255,0.06)",
      "5": "0 24px 48px rgba(0,0,0,0.75), inset 0 1px 0 rgba(255,255,255,0.06)"
    }
  },
  "z": {
    "base": 0, "raised": 10, "dropdown": 1000, "sticky": 1100, "drawer": 1200,
    "modal": 1300, "popover": 1400, "toast": 1500, "tooltip": 1600, "celebration": 1700, "debug": 9999
  },
  "container": {
    "sm": 640, "md": 768, "lg": 1024, "xl": 1280, "2xl": 1536
  },
  "breakpoint": {
    "xs": 360, "sm": 640, "md": 768, "lg": 1024, "xl": 1280, "2xl": 1536
  },
  "motion": {
    "ease": {
      "standard":   "cubic-bezier(0.2, 0.0, 0.0, 1.0)",
      "decelerate": "cubic-bezier(0.0, 0.0, 0.2, 1.0)",
      "accelerate": "cubic-bezier(0.4, 0.0, 1.0, 1.0)",
      "emphasized": "cubic-bezier(0.2, 0.0, 0.0, 1.0)",
      "spring":     "cubic-bezier(0.34, 1.56, 0.64, 1.0)",
      "linear":     "cubic-bezier(0, 0, 1, 1)"
    },
    "duration": {
      "instant":     0,
      "micro":       80,
      "short":       160,
      "medium":      240,
      "long":        420,
      "celebration": 1200
    }
  }
}
