# Kipindi — environment variables (copy to .env.local)

# Database (PostgreSQL)
DATABASE_URL="postgresql://kipindi:kipindi@localhost:5432/kipindi?schema=public"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Auth (set real secrets before running)
SESSION_SECRET=""
OTP_PEPPER=""

# SMS (Sprint 1)
SMS_PROVIDER=""           # selcom | beem | africastalking
SMS_API_KEY=""
SMS_SENDER_ID="KIPINDI"

# Mobile money aggregator (Sprint 2)
PAYMENT_AGGREGATOR=""     # selcom | azampay
PAYMENT_API_KEY=""
PAYMENT_API_SECRET=""
PAYMENT_WEBHOOK_SECRET=""

# Sports data (Sprint 3) — start with API-Football
SPORTS_API_PROVIDER="api-football"
SPORTS_API_KEY=""

# NIDA verification (Sprint 1)
NIDA_API_URL=""
NIDA_API_KEY=""

# Match integrity monitoring (later sprint)
INTEGRITY_PROVIDER=""     # sportradar-integrity | none
INTEGRITY_API_KEY=""

# Push notifications
FCM_SERVER_KEY=""
APN_KEY_ID=""
APN_TEAM_ID=""
