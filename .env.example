# Kipindi — environment variables (copy to .env.local)

# Database (PostgreSQL)
DATABASE_URL="postgresql://kipindi:kipindi@localhost:5432/kipindi?schema=public"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Auth (set real secrets before running)
SESSION_SECRET=""
OTP_PEPPER=""

# SMS (Sprint 1)
SMS_PROVIDER=""           # selcom | beem | africastalking
SMS_API_KEY=""
SMS_SENDER_ID="KIPINDI"

# Mobile money aggregator (Sprint 2)
PAYMENT_AGGREGATOR=""     # selcom | azampay
PAYMENT_API_KEY=""
PAYMENT_API_SECRET=""
# Per-provider webhook HMAC secrets. These EXACT names are read by
# api/webhooks/payments/route.ts — one per provider you enable. Setting a single
# PAYMENT_WEBHOOK_SECRET does NOTHING: every callback would 401 and deposits
# would never credit (audit H7). Boot warns in production if any is missing.
SELCOM_WEBHOOK_SECRET=""
AZAMPAY_WEBHOOK_SECRET=""
MIXX_WEBHOOK_SECRET=""
# Transactional email (Postmark) inbound webhook — api/webhooks/postmark/route.ts
POSTMARK_WEBHOOK_SECRET=""

# KYC document object storage (audit H8) — src/lib/server/storage.ts.
# Default (unset) stores KYC images INLINE (base64 data URL) in Postgres.
# Set KYC_STORAGE=r2 + the R2 creds below to store them in Cloudflare R2 instead
# (also: npm i @aws-sdk/client-s3). Old inline rows keep working.
KYC_STORAGE=""                 # "" (inline) | r2
R2_ENDPOINT=""                 # https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""

# Error monitoring (audit H6) — src/lib/server/monitoring.ts. Set the DSN +
# `npm i @sentry/node` to ship server errors to Sentry (no-op until then).
SENTRY_DSN=""

# Redis (audit H2) — OPTIONAL and FAIL-OPEN. src/lib/server/redis.ts.
# Buys exactly three things: cross-container rate limits, SSE fan-out, and queue
# telemetry. NEVER on the bet/admission path; a Redis outage costs shared limits
# and live updates, never a bet, a login or a withdrawal.
#
# ⚠️ TWO KEYS ARM IT. REDIS_URL alone does NOTHING — REDIS_ENABLED must also be
# exactly "true". They are separate on purpose: the Railway project carries Redis
# tiles and docs/CLOUDFLARE-SETUP-GUIDE.md has an operator wire `${{Redis.REDIS_URL}}`
# for unrelated reasons, so if the URL were the on-switch a variable edit made
# while following a CDN runbook would move every login/OTP/deposit onto a Lua
# bucket with no deploy and no review. REDIS_ENABLED="false" is also the instant
# rollback — no need to delete a service reference.
REDIS_ENABLED="false"
REDIS_URL=""

# Sports data (Sprint 3) — start with API-Football
SPORTS_API_PROVIDER="api-football"
SPORTS_API_KEY=""

# NIDA verification (Sprint 1)
NIDA_API_URL=""
NIDA_API_KEY=""

# Match integrity monitoring (later sprint)
INTEGRITY_PROVIDER=""     # sportradar-integrity | none
INTEGRITY_API_KEY=""

# Push notifications
FCM_SERVER_KEY=""
APN_KEY_ID=""
APN_TEAM_ID=""
